# ============================================================
# Pastel Royalty — Environment Variables
# ============================================================
# Copy to .env and fill in your values.
# Without Supabase vars, the site runs on demo data with mailto fallback.

# Supabase (optional — enables database, inquiry form, contacts CRM)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gallery identity
VITE_SITE_NAME=Pastel Royalty Gallery
VITE_GALLERY_EMAIL=info@yourgallery.com
